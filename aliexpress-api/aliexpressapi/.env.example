DJANGO_SETTINGS_MODULE=configs.settings.dev
DEBUG=true
SECRET_KEY=replace-with-a-long-random-development-secret
JWT_SIGNING_KEY=replace-with-a-long-random-jwt-signing-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ENFORCE_KYC=false
LOG_LEVEL=INFO
RABBITMQ_URL=amqp://aliexpress:change-me@localhost:5672/%2F
RABBITMQ_EXCHANGE=marketplace.events
OUTBOX_MAX_ATTEMPTS=5
OUTBOX_RETRY_BASE_SECONDS=30
OUTBOX_LEASE_SECONDS=300
METRICS_BEARER_TOKEN=change-me-before-production
